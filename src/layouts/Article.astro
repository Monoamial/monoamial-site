---
import Base from './Base.astro';
const { data, section } = Astro.props;
const d = data.date
  ? new Date(data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';
const sectionColors = {
  research: 'var(--accent)',
  code: 'var(--accent-2)',
  writing: 'var(--accent-3)',
  teaching: 'var(--accent-4)',
};
const sectionColor = sectionColors[section] ?? 'var(--accent)';
const links = [
  data.pdf && { href: data.pdf, label: 'PDF' },
  data.repo && { href: data.repo, label: 'Repository' },
  data.demo && { href: data.demo, label: 'Live demo' },
  data.link && { href: data.link, label: 'Link' },
].filter(Boolean);
---
<Base title={data.title} description={data.description}>
  <article style={`--section-color: ${sectionColor}`}>
    <a href={`/${section}/`} class="back">&larr; {section}</a>
    <header class="art-head">
      <h1>{data.title}</h1>
      <p class="art-meta">
        {d}
        {data.coauthors?.length ? ` · with ${data.coauthors.join(', ')}` : ''}
        {data.role ? ` · ${data.role}` : ''}
        {data.term ? ` · ${data.term}` : ''}
      </p>
      <div class="art-tags">
        {(data.stack ?? []).map((s) => <span class="badge">{s}</span>)}
        {(data.tags ?? []).map((t) => <span class="tag">#{t}</span>)}
      </div>
      {links.length > 0 && (
        <div class="art-links">
          {links.map((l) => <a href={l.href}>{l.label}</a>)}
        </div>
      )}
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</Base>
<style>
  article { margin: 1.5rem 0; }
  .back { font-family: var(--font-label); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.13em; color: var(--section-color); }
  .art-head h1 { color: var(--section-color); }
  .art-head { margin: 0.6rem 0 2rem; border-bottom: 2px solid var(--board-edge); padding-bottom: 1.2rem; }
  .art-meta { font-family: var(--font-body); font-style: italic; font-size: 0.95rem; color: var(--chalk-faint); margin: 0.2rem 0; }
  .art-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.6rem; }
  .badge { font-family: var(--font-label); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent); border: 1px solid color-mix(in srgb, var(--accent) 45%, transparent); border-radius: 4px; padding: 0.1em 0.55em; }
  .art-links { display: flex; gap: 1.2rem; margin-top: 0.9rem; }
  .art-links a { font-family: var(--font-label); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.13em; }
  .prose :global(img) { max-width: 100%; border-radius: 8px; border: 1px solid var(--board-edge); }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin: 1.2em 0; }
  .prose :global(th), .prose :global(td) { border: 1px solid var(--board-edge); padding: 0.4em 0.7em; text-align: left; }
</style>
